---
import { LuArrowLeft, LuArrowRight, LuBookMarked } from "react-icons/lu";
import Alert from "@/components/Alert";
import Button from "@/components/Button";
import { H1, H2 } from "@/components/Heading";
import TableOfContents from "@/components/TableOfContents";
import Tag from "@/components/Tag";
import EvidenceTable from "@/critria/EvidenceTable";
import Layout from "@/layouts/Layout.astro";
import { parse } from "@/util/markdown";
import curations from "~/criTRia-curations.json";

/** generate pages for each datum, paths based on id */
export const getStaticPaths = async () =>
  curations.map(({ Locus_ID }) => ({ params: { id: Locus_ID } }));

/** current page curation id in url */
const { id } = Astro.params;

/** look up full curation entry from id */
const curation = curations.find((item) => item.Locus_ID === id);

if (!curation) throw new Error(`no curation found for locus: ${id}`);

const nice_id = curation.Locus_ID.split("_").join(" ");
---

<Layout title={`Curation ${nice_id}`}>
  <TableOfContents client:only="react" />

  <section>
    <H1><LuBookMarked />Curation {nice_id}</H1>

    <Button
      className="w-60 self-center"
      to={`/loci/${curation.Locus_ID}`}
      design="bubble"
    >
      Locus Page<LuArrowRight />
    </Button>

    <div class="boxes">
      <div class="box">
        <strong>Gene</strong>
        {curation.Gene}
      </div>
      <div class="box">
        <strong>Disease</strong>
        {curation.Disease_ID}
      </div>
      <div class="box">
        <strong>Inheritance</strong>
        {curation.Inheritance ?? "–"}
      </div>
      <div class="box">
        <strong>Classification</strong>
        <Tag value={curation.classification} />
      </div>
      <div class="box">
        <strong>Total Score</strong>
        {curation.total_score}
      </div>
      <div class="box">
        <strong>Publications Reviewed</strong>
        {curation.publication_count ?? "–"}
      </div>
      <div class="box">
        <strong>Publication Span</strong>
        {
          curation.publication_interval_years != null
            ? `${curation.publication_interval_years} years`
            : "–"
        }
      </div>
      <div class="box">
        <strong>Publication Interval</strong>
        {
          curation.publication_interval_years != null
            ? `${curation.publication_interval_years} years`
            : "–"
        }
      </div>
      <div class="box">
        <strong>Last Updated</strong>
        {curation.Date}
      </div>
      <div class="box-2">
        <strong>Curator(s)</strong>
        {curation.Curator}
      </div>
    </div>

    {
      curation.Description && (
        <>
          <H2>Description</H2>

          <div set:html={parse(curation.Description)} />
        </>
      )
    }

    <Button className="w-60 self-center" to="/critria" design="bubble">
      <LuArrowLeft />All CriTRia Curations
    </Button>
  </section>

  <section>
    <H2>Genetic evidence</H2>
    <p class="text-center text-balance">
      <strong>Total:</strong>
      {curation.supercategory_summary?.["Genetic Evidence"] ?? "-"}
    </p>

    {
      curation.genetic_evidence_details?.length ? (
        <EvidenceTable
          client:load
          evidence={curation.genetic_evidence_details ?? []}
        />
      ) : (
        <p class="text-center text-balance">
          No genetic evidence details available.
        </p>
      )
    }
  </section>

  <section>
    <H2>Experimental evidence</H2>
    <p class="text-center text-balance">
      <strong>Total:</strong>
      {curation.supercategory_summary?.["Experimental Evidence"] ?? "-"}
    </p>

    {
      curation.experimental_evidence_details?.length ? (
        <EvidenceTable
          client:load
          evidence={curation.experimental_evidence_details ?? []}
        />
      ) : (
        <p class="text-center text-balance">
          No experimental evidence details available.
        </p>
      )
    }
  </section>

  <section>
    <Alert>
      Maximum score caps apply at evidence type, category, and supercategory
      levels, so section totals may be lower than the raw sum of row scores.
    </Alert>
  </section>
</Layout>
