---
import Logo from "@/assets/logo.svg?react";
import Button from "@/components/Button";
import Layout from "@/layouts/Layout.astro";
import { IconNews, IconTallymark4 } from "@tabler/icons-react";
---

<Layout title="Home">
  <section slot="header" class="bg-transparent text-white">
    <div class="flex flex-col items-center gap-4">
      <Logo className="h-20 max-w-full" data-animated />
      <div class="text-center" role="heading" aria-level="1">
        <em>"ess-tee archive"</em>, short tandem repeat archive
      </div>
    </div>

    <p class="text-center text-lg text-balance">
      An archive of STRs associated with human diseases
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <Button className="w-40" design="bubble" to="/loci">
        Loci<IconTallymark4 />
      </Button>
      <Button
        className="w-40"
        design="bubble"
        to="https://doi.org/10.1186/s13073-025-01454-4"
      >
        Paper<IconNews />
      </Button>
    </div>
  </section>

  <section class="width-sm">
    <p>
      Short Tandem Repeats (STRs) are a type of genetic variation that are
      associated with many rare diseases. Information about pathogenic STRs is
      often out-of-date and scattered across different databases, making it
      difficult to find and interpret STR variants.
      <strong>STRchive</strong> aims to solve this problem by providing a central
      community resource.
    </p>
  </section>
</Layout>
